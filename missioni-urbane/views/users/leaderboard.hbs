<a href="/" class="btn btn-outline mb-3">&larr; Torna alle missioni</a>
<h1 class="mb-3 text-green text-center">Classifica Agenti</h1>
<div class="card mx-auto" style="max-width: 600px;">
  <table class="table" style="width: 100%; text-align: left; border-collapse: collapse;">
    <thead>
      <tr style="border-bottom: 1px solid var(--border);">
        <th style="padding: 10px;">Posizione</th>
        <th style="padding: 10px;">Nome in codice</th>
        <th style="padding: 10px;">Punti Reputazione</th>
      </tr>
    </thead>
    <tbody>
      {{#each leaderboard}}
      <tr style="border-bottom: 1px solid var(--border);">
        <td style="padding: 10px;">#{{@index}}</td>
        <td style="padding: 10px;">{{username}}</td>
        <td style="padding: 10px; color: var(--accent-amber); font-weight: bold;">{{points}}</td>
      </tr>
      {{/each}}
    </tbody>
  </table>
</div>
