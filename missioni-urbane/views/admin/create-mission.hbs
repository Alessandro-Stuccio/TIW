<a href="/admin" class="btn btn-outline mb-3">&larr; Torna alla Dashboard</a>

<div class="card" style="max-width: 600px; margin: 0 auto;">
  <h2 class="text-green mb-3">Crea Nuova Missione</h2>
  
  {{#if errors}}
    <div class="alert alert-error mb-3">
      <ul style="margin:0; padding-left:18px;">
        {{#each errors}}<li>{{this}}</li>{{/each}}
      </ul>
    </div>
  {{/if}}
  
  <form action="/admin/create-mission" method="POST">
    <div class="form-group">
      <label class="form-label">Titolo Missione</label>
      <input type="text" name="title" class="form-control" required>
    </div>
    
    <div class="form-group">
      <label class="form-label">Descrizione</label>
      <textarea name="description" class="form-control" rows="4" required></textarea>
    </div>
    
    <div class="form-group">
      <label class="form-label">Ricompensa (Punti)</label>
      <input type="number" name="points" class="form-control" value="10" required>
    </div>
    
    <div class="form-group">
      <label class="form-label">Difficoltà</label>
      <select name="difficulty" class="form-control">
        <option value="facile">Facile</option>
        <option value="media">Media</option>
        <option value="difficile">Difficile</option>
      </select>
    </div>
    
    <div class="form-group">
      <label class="form-label">Categoria</label>
      <input type="text" name="category" class="form-control" placeholder="es. ricognizione, sabotaggio..." required>
    </div>

    <div class="form-group">
      <label class="form-label">Latitudine (Opzionale per Mappa)</label>
      <input type="number" step="any" name="lat" class="form-control">
    </div>

    <div class="form-group">
      <label class="form-label">Longitudine (Opzionale per Mappa)</label>
      <input type="number" step="any" name="lng" class="form-control">
    </div>

    <div class="form-group">
      <label class="form-label">Location (Testo)</label>
      <input type="text" name="location" class="form-control" required>
    </div>
    
    <button type="submit" class="btn btn-primary btn-block">Autorizza e Pubblica</button>
  </form>
</div>
