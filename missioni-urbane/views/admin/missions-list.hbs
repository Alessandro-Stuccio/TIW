<a href="/admin" class="btn btn-outline mb-3">&larr; Torna alla Dashboard HQ</a>

<h1 class="text-green mb-3">Gestione Missioni</h1>

<div class="mb-4">
  <a href="/admin/create-mission" class="btn btn-primary">Crea Nuova Missione</a>
</div>

{{#if missions.length}}
  <div class="grid grid-2">
    {{#each missions}}
      <div class="card mb-3">
        <h3 class="text-green mb-2">{{title}}</h3>
        <p class="text-muted"><strong>Status:</strong> {{status}} | <strong>Categoria:</strong> {{category}} | <strong>Difficoltà:</strong> {{difficulty}}</p>
        <p class="mb-3">{{description}}</p>
        
        <div style="display: flex; gap: 10px;">
          <a href="/admin/missions/{{id}}/edit" class="btn btn-outline" style="flex: 1; text-align: center;">Modifica</a>
          
          {{#if (eq status 'attiva')}}
          <form action="/admin/missions/{{id}}/archive" method="POST" style="flex: 1;">
            <button type="submit" class="btn btn-danger btn-block" onclick="return confirm('Sei sicuro di voler archiviare questa missione?')">Archivia</button>
          </form>
          {{/if}}
        </div>
      </div>
    {{/each}}
  </div>
{{else}}
  <div class="card text-center">
    <p>Nessuna missione trovata.</p>
  </div>
{{/if}}
