<a href="/admin" class="btn btn-outline mb-3">&larr; Torna alla Dashboard</a>

<h1 class="text-green mb-3">Revisione Prove</h1>

{{#if pendings.length}}
  <div class="grid grid-2">
    {{#each pendings}}
      <div class="card mb-3">
        <h3 class="text-green mb-2">Missione: {{mission_title}}</h3>
        <p><strong>Agente:</strong> <span style="color: var(--accent-amber);">{{username}}</span></p>
        
        {{#if proof_text}}
          <div class="mt-2 mb-2">
            <strong>Rapporto della Prova:</strong>
            <p style="background: var(--bg-primary); padding: 15px; border-radius: 4px; border: 1px dashed var(--border); margin-top: 5px; font-family: var(--font-body);">
              {{proof_text}}
            </p>
          </div>
        {{/if}}

        {{#if proof_image}}
          <div class="mt-2 mb-2">
            <strong>Fotografia:</strong><br>
            <img src="{{proof_image}}" alt="Prova" style="max-width: 100%; border: 1px solid var(--border); border-radius: 4px; margin-top: 5px;">
          </div>
        {{/if}}

        <div style="display: flex; gap: 15px; margin-top: 20px;">
          <form action="/admin/verify-proofs/{{id}}/approve" method="POST" style="flex: 1;">
            <button type="submit" class="btn btn-primary btn-block">Approva</button>
          </form>
          
          <form action="/admin/verify-proofs/{{id}}/reject" method="POST" style="flex: 1; display: flex; flex-direction: column; gap: 10px;">
            <input type="text" name="feedback" class="form-control" placeholder="Motivo del rifiuto" style="font-size: 0.85rem;">
            <button type="submit" class="btn btn-danger btn-block">Rifiuta</button>
          </form>
        </div>
      </div>
    {{/each}}
  </div>
{{else}}
  <div class="card" style="max-width: 600px; margin: 0 auto; text-align: center; padding: 40px;">
    <h3 class="text-green">Tutto in regola!</h3>
    <p class="text-muted mt-2">Nessuna prova in attesa. La base è sicura.</p>
  </div>
{{/if}}
