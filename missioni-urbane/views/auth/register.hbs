<a href="/" class="btn btn-outline mb-3">&larr; Torna alle missioni</a>
<div style="max-width: 400px; margin: 0 auto; margin-top: 50px;">
  <div class="card">
    <h2 class="card-title text-green text-center mb-3">Nuova Recluta.</h2>
    <form action="/auth/register" method="POST">
      <div class="form-group">
        <label class="form-label">Nome in codice (Username)</label>
        <input type="text" name="username" class="form-control" placeholder="es. ShadowRunner" required value="{{username}}">
      </div>
      <div class="form-group">
        <label class="form-label">Email Ufficiale</label>
        <input type="email" name="email" class="form-control" placeholder="email@dominio.com" required value="{{email}}">
      </div>
      <div class="form-group">
        <label class="form-label">Password</label>
        <input type="password" name="password" class="form-control" placeholder="Minimo 6 caratteri" required>
      </div>
      <button type="submit" class="btn btn-primary btn-block mb-2">Invia Richiesta</button>
    </form>
    <div class="text-center" style="font-size: 0.8rem;">
      <span class="text-muted">Già nei ranghi?</span> <a href="/auth/login">Entra</a>
    </div>
  </div>
</div>
